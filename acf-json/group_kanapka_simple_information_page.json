        { "key": "field_ksip_gallery_tab", "label": "Gallery", "name": "", "type": "tab", "placement": "top" },
        { "key": "field_ksip_gallery_enabled", "label": "Enable gallery", "name": "kanapka_simple_page_gallery_enabled", "type": "true_false", "default_value": 0, "ui": 1, "ui_on_text": "Yes", "ui_off_text": "No" },
