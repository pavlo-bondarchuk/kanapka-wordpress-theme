        { "key": "field_ksip_gallery", "label": "Gallery images", "name": "kanapka_simple_page_gallery", "type": "gallery", "instructions": "Preview images use a consistent 4:3 crop and open in a lightbox slider.", "return_format": "id", "preview_size": "medium", "insert": "append", "library": "all", "mime_types": "jpg,jpeg,png,webp,avif", "conditional_logic": [[{ "field": "field_ksip_gallery_enabled", "operator": "==", "value": "1" }]] },

        { "key": "field_ksip_cta_tab", "label": "Call to action", "name": "", "type": "tab", "placement": "top" },
