        { "key": "field_ksip_products_source", "label": "Product source", "name": "kanapka_simple_page_products_source", "type": "select", "choices": { "manual": "Manual selection", "category": "Product category", "featured": "Featured products", "related": "Related products" }, "default_value": "manual", "return_format": "value", "conditional_logic": [[{ "field": "field_ksip_products_enabled", "operator": "==", "value": "1" }]] },
        { "key": "field_ksip_products", "label": "Products", "name": "kanapka_simple_page_products", "type": "relationship", "post_type": ["product"], "filters": ["search", "taxonomy"], "return_format": "id", "conditional_logic": [[{ "field": "field_ksip_products_source", "operator": "==", "value": "manual" }]] },
        { "key": "field_ksip_products_category", "label": "Product category", "name": "kanapka_simple_page_products_category", "type": "taxonomy", "taxonomy": "product_cat", "field_type": "select", "allow_null": 1, "add_term": 0, "save_terms": 0, "load_terms": 0, "return_format": "id", "conditional_logic": [[{ "field": "field_ksip_products_source", "operator": "==", "value": "category" }]] },
        { "key": "field_ksip_related_product", "label": "Reference product", "name": "kanapka_simple_page_related_product", "type": "post_object", "instructions": "Products related to this item will be displayed.", "post_type": ["product"], "return_format": "id", "allow_null": 1, "conditional_logic": [[{ "field": "field_ksip_products_source", "operator": "==", "value": "related" }]] },
