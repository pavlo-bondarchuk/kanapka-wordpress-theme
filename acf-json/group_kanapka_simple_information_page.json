        { "key": "field_ksip_products_link", "label": "View all link", "name": "kanapka_simple_page_products_link", "type": "link", "return_format": "array", "wrapper": { "width": "70", "class": "", "id": "" }, "conditional_logic": [[{ "field": "field_ksip_products_enabled", "operator": "==", "value": "1" }]] },

