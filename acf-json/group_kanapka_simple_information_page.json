                { "key": "field_ksip_cta_button_style", "label": "Style", "name": "style", "type": "select", "choices": { "primary": "Primary", "secondary": "Secondary" }, "default_value": "primary", "return_format": "value", "wrapper": { "width": "30", "class": "", "id": "" }, "parent_repeater": "field_ksip_cta_buttons" }
            ]
        },

        { "key": "field_ksip_products_tab", "label": "Products", "name": "", "type": "tab", "placement": "top" },
