        { "key": "field_ksip_intro", "label": "Introduction", "name": "kanapka_simple_page_intro", "type": "wysiwyg", "instructions": "Optional highlighted introduction above the main content.", "tabs": "all", "toolbar": "basic", "media_upload": 0, "delay": 0 },
