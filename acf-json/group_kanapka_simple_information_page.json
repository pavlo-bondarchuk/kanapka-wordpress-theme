        { "key": "field_ksip_cta_title", "label": "Title", "name": "kanapka_simple_page_cta_title", "type": "text", "conditional_logic": [[{ "field": "field_ksip_cta_enabled", "operator": "==", "value": "1" }]] },
        { "key": "field_ksip_cta_text", "label": "Text", "name": "kanapka_simple_page_cta_text", "type": "wysiwyg", "tabs": "all", "toolbar": "basic", "media_upload": 0, "delay": 0, "conditional_logic": [[{ "field": "field_ksip_cta_enabled", "operator": "==", "value": "1" }]] },
